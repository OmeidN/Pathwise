<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Backend Search Test</title>
</head>
<body>
    <!-- test area -->
    <div style="padding: 20px;">
        <h2>Test Home Page</h2>
        <p>Team 2 - Backend Integration Test</p>
        
        <div style="margin: 20px 0;">
            <form id="searchForm">
                <!-- text search -->
                <div style="margin-bottom: 10px;">
                    <label for="searchInput">Search:</label><br>
                    <input type="text" id="searchInput" name="q" placeholder="e.g., internship, study tips, etc" 
                           style="width: 300px; padding: 5px;">
                </div>
                
                <!-- category dropdown -->
                <div style="margin-bottom: 10px;">
                    <label for="category">Category:</label><br>
                    <select id="category" name="category" style="width: 200px; padding: 5px;">
                        <option value="">All Categories</option>
                        <option value="academic">Academic</option>
                        <option value="career">Career</option>
                        <option value="personal">Personal</option>
                        <option value="other">other</option>
                    </select>
                </div>
                
                <button type="submit" style="padding: 5px 15px;">Test Search</button>
            </form>
        </div>
        
        <!-- results area -->
        <div id="results" style="margin-top: 30px; border-top: 1px solid #ccc; padding-top: 20px;">
            <h3>Results:</h3>
            <pre id="resultsContent" style="background: #f5f5f5; padding: 15px; border-radius: 5px; overflow: auto;">
Waiting for input
            </pre>
        </div>
    </div>

    <script>
        // src="js/search-test.js"
        document.getElementById('searchForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const searchTerm = document.getElementById('searchInput').value;
            const category = document.getElementById('category').value;
            
            //visualized loading state
            const resultsEl = document.getElementById('resultsContent');
            resultsEl.textContent = 'Searching...';
            
            try {
                //build the query string
                const params = new URLSearchParams();
                if (searchTerm) params.append('q', searchTerm);
                if (category) params.append('category', category);
                
                //for future api call to backend
                const response = await fetch(`/api/search?${params.toString()}`);
                const data = await response.json();
                
                //display formatted JSON results
                resultsEl.textContent = JSON.stringify(data, null, 2);
            } catch (error) {
                resultsEl.textContent = `Error: ${error.message}`;
            }
        });
    </script>
</body>
</html>