# Local development
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=localdev
DB_NAME=pathwise

# Set true for cloud MySQL (TiDB, PlanetScale, etc.)
# DB_SSL=true

# Required for sessions (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Required on Render (HTTPS)
# COOKIE_SECURE=true

# Google Gemini (AI goal planning)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT_MS=45000
# GEMINI_MAX_OUTPUT_TOKENS=1800

# Optional
# PORT=3000
# NODE_ENV=production
